# ============================================================
# Veloura Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Backend API --------------------------------------------
# Used in apollo/client.ts
# Point to your deployed backend (Railway / VPS / localhost)
NEXT_PUBLIC_API_GRAPHQL_URL=https://<backend-domain>/graphql
NEXT_PUBLIC_API_WS=wss://<backend-domain>

# ---- Examples (local dev) -----------------------------------
# NEXT_PUBLIC_API_GRAPHQL_URL=http://localhost:3000/graphql
# NEXT_PUBLIC_API_WS=ws://localhost:4001
